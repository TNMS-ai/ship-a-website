---
import Layout from './Layout.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  category?: string;
}

const { title, description, category } = Astro.props;

const allEntries = await getCollection('design-system');

type NavSection = {
  label: string;
  items: { title: string; slug: string }[];
};

const categories: { key: string; label: string }[] = [
  { key: 'components', label: 'Components' },
  { key: 'styles', label: 'Styles' },
  { key: 'templates', label: 'Templates' },
  { key: 'guides', label: 'Guides' },
];

const navSections: NavSection[] = categories.map(({ key, label }) => ({
  label,
  items: allEntries
    .filter((e) => e.data.category === key)
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
    .map((e) => ({ title: e.data.title, slug: e.id })),
})).filter((s) => s.items.length > 0);

const currentPath = Astro.url.pathname;
---

<Layout title={title} description={description} noIndex={true}>
  <div class="design-system-layout">
    <aside class="design-system-layout__sidebar" aria-label="Design system navigation">
      <a href="/design-system/" class="design-system-layout__home-link">
        Design System
      </a>
      <nav class="design-system-layout__nav">
        {navSections.map((section) => (
          <div class="design-system-layout__section">
            <p class="design-system-layout__section-label">{section.label}</p>
            <ul class="design-system-layout__nav-list">
              {section.items.map((item) => {
                const href = `/design-system/${item.slug}/`;
                const isActive = currentPath === href || currentPath === href.slice(0, -1);
                return (
                  <li>
                    <a
                      href={href}
                      class={`design-system-layout__nav-link${isActive ? ' design-system-layout__nav-link--active' : ''}`}
                    >
                      {item.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <main id="main" class="design-system-layout__content">
      {category && (
        <p class="site-eyebrow--paper">{category}</p>
      )}
      <article class="design-system-layout__article prose">
        <slot />
      </article>
    </main>
  </div>
</Layout>

<style>
  .design-system-layout {
    display: grid;
    grid-template-columns: 16rem 1fr;
    min-height: 100vh;
    max-width: var(--container-wide);
    margin: 0 auto;
  }

  .design-system-layout__sidebar {
    border-right: 1px solid var(--color-ink-800);
    padding: 2rem 1.5rem;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .design-system-layout__home-link {
    display: block;
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-signal-400);
    text-decoration: none;
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .design-system-layout__home-link:hover {
    color: var(--color-signal-300);
  }

  .design-system-layout__section {
    margin-bottom: 1.5rem;
  }

  .design-system-layout__section-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-500);
    margin-bottom: 0.5rem;
  }

  .design-system-layout__nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .design-system-layout__nav-link {
    display: block;
    padding: 0.3rem 0.75rem;
    border-radius: 0.25rem;
    font-size: var(--text-sm);
    color: var(--color-ink-300);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard);
  }

  .design-system-layout__nav-link:hover {
    color: var(--color-ink-50);
    background-color: var(--color-ink-800);
  }

  .design-system-layout__nav-link--active {
    color: var(--color-signal-400);
    background-color: var(--color-ink-800);
  }

  .design-system-layout__content {
    padding: 3rem 3rem 4rem;
    min-width: 0;
  }

  .design-system-layout__article {
    max-width: var(--container-prose);
  }

  @media (max-width: 768px) {
    .design-system-layout {
      grid-template-columns: 1fr;
    }

    .design-system-layout__sidebar {
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--color-ink-800);
    }
  }
</style>
